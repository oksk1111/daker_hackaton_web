{
  "designSystem": {
    "name": "Daker Hackathon - Freshworks Inspired Design",
    "version": "1.0.0",
    "description": "Modern, clean, professional design inspired by Freshworks/Freshrelease"
  },
  "colors": {
    "primary": {
      "50": "#f3f0ff",
      "100": "#e9e3ff",
      "200": "#d4c8ff",
      "300": "#b49fff",
      "400": "#9370ff",
      "500": "#7C3AED",
      "600": "#6D28D9",
      "700": "#5B21B6",
      "800": "#4C1D95",
      "900": "#3B0764"
    },
    "secondary": {
      "50": "#f0fdf4",
      "100": "#dcfce7",
      "200": "#bbf7d0",
      "300": "#86efac",
      "400": "#4ade80",
      "500": "#22c55e",
      "600": "#16a34a"
    },
    "accent": {
      "orange": "#f97316",
      "cyan": "#06b6d4",
      "pink": "#ec4899"
    },
    "neutral": {
      "white": "#FFFFFF",
      "50": "#FAFAFA",
      "100": "#F5F5F5",
      "200": "#E5E5E5",
      "300": "#D4D4D4",
      "400": "#A3A3A3",
      "500": "#737373",
      "600": "#525252",
      "700": "#404040",
      "800": "#262626",
      "900": "#171717"
    },
    "background": {
      "page": "#FFFFFF",
      "card": "#FFFFFF",
      "section": "#FAFAFA",
      "hero": "#FFFFFF"
    },
    "status": {
      "upcoming": {
        "bg": "#dbeafe",
        "text": "#1d4ed8"
      },
      "ongoing": {
        "bg": "#dcfce7",
        "text": "#15803d"
      },
      "ended": {
        "bg": "#f3f4f6",
        "text": "#6b7280"
      },
      "error": {
        "bg": "#fef2f2",
        "text": "#dc2626"
      },
      "warning": {
        "bg": "#fffbeb",
        "text": "#d97706"
      },
      "info": {
        "bg": "#eff6ff",
        "text": "#2563eb"
      }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "Geist, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "mono": "Geist Mono, 'Fira Code', monospace"
    },
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem"
    },
    "fontWeight": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.25,
      "normal": 1.5,
      "relaxed": 1.75
    },
    "heading": {
      "hero": {
        "size": "3rem",
        "weight": 700,
        "color": "neutral.900",
        "letterSpacing": "-0.02em"
      },
      "page": {
        "size": "1.875rem",
        "weight": 700,
        "color": "neutral.900"
      },
      "section": {
        "size": "1.5rem",
        "weight": 700,
        "color": "neutral.800"
      },
      "card": {
        "size": "1.125rem",
        "weight": 700,
        "color": "neutral.800"
      }
    },
    "body": {
      "primary": {
        "size": "1rem",
        "color": "neutral.700"
      },
      "secondary": {
        "size": "0.875rem",
        "color": "neutral.500"
      },
      "caption": {
        "size": "0.75rem",
        "color": "neutral.400"
      }
    }
  },
  "spacing": {
    "page": {
      "maxWidth": "72rem",
      "paddingX": "1rem",
      "paddingY": "2rem"
    },
    "section": {
      "gap": "3rem",
      "paddingY": "2rem"
    },
    "card": {
      "padding": "1.5rem",
      "gap": "1rem"
    },
    "element": {
      "xs": "0.25rem",
      "sm": "0.5rem",
      "md": "1rem",
      "lg": "1.5rem",
      "xl": "2rem",
      "2xl": "3rem"
    }
  },
  "borderRadius": {
    "sm": "0.375rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "2xl": "1.5rem",
    "full": "9999px",
    "button": "9999px",
    "card": "1rem",
    "input": "0.5rem",
    "tag": "9999px"
  },
  "shadows": {
    "none": "none",
    "sm": "0 1px 2px rgba(0, 0, 0, 0.05)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.07), 0 2px 4px -2px rgba(0, 0, 0, 0.05)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.04)",
    "card": "0 1px 3px rgba(0, 0, 0, 0.06)",
    "cardHover": "0 8px 25px rgba(0, 0, 0, 0.08)",
    "navbar": "0 1px 3px rgba(0, 0, 0, 0.05)"
  },
  "borders": {
    "default": {
      "width": "1px",
      "style": "solid",
      "color": "neutral.200"
    },
    "light": {
      "width": "1px",
      "style": "solid",
      "color": "neutral.100"
    }
  },
  "components": {
    "navbar": {
      "height": "4rem",
      "background": "#FFFFFF",
      "borderBottom": "1px solid #E5E5E5",
      "shadow": "0 1px 3px rgba(0, 0, 0, 0.05)",
      "logo": {
        "fontSize": "1.25rem",
        "fontWeight": 700,
        "color": "#7C3AED"
      },
      "link": {
        "fontSize": "0.875rem",
        "fontWeight": 500,
        "color": "#525252",
        "hoverColor": "#7C3AED",
        "activeBackground": "#f3f0ff",
        "activeColor": "#6D28D9"
      },
      "signUpButton": {
        "background": "#7C3AED",
        "color": "#FFFFFF",
        "borderRadius": "9999px",
        "paddingX": "1.5rem",
        "paddingY": "0.5rem"
      }
    },
    "heroSection": {
      "background": "#FFFFFF",
      "paddingY": "5rem",
      "title": {
        "fontSize": "3rem",
        "fontWeight": 700,
        "color": "#171717",
        "lineHeight": 1.2
      },
      "subtitle": {
        "fontSize": "1.125rem",
        "color": "#737373",
        "maxWidth": "40rem"
      },
      "ctaButton": {
        "background": "#7C3AED",
        "hoverBackground": "#6D28D9",
        "color": "#FFFFFF",
        "borderRadius": "9999px",
        "paddingX": "2rem",
        "paddingY": "0.875rem",
        "fontSize": "0.875rem",
        "fontWeight": 600,
        "textTransform": "uppercase",
        "letterSpacing": "0.05em"
      }
    },
    "card": {
      "background": "#FFFFFF",
      "borderRadius": "1rem",
      "border": "1px solid #E5E5E5",
      "padding": "1.5rem",
      "shadow": "0 1px 3px rgba(0, 0, 0, 0.06)",
      "hoverShadow": "0 8px 25px rgba(0, 0, 0, 0.08)",
      "hoverTranslateY": "-2px",
      "transition": "all 0.2s ease"
    },
    "button": {
      "primary": {
        "background": "#7C3AED",
        "hoverBackground": "#6D28D9",
        "color": "#FFFFFF",
        "borderRadius": "9999px",
        "fontWeight": 600,
        "fontSize": "0.875rem"
      },
      "secondary": {
        "background": "#F5F5F5",
        "hoverBackground": "#E5E5E5",
        "color": "#525252",
        "borderRadius": "0.5rem",
        "fontWeight": 500,
        "fontSize": "0.875rem"
      },
      "ghost": {
        "background": "transparent",
        "hoverBackground": "#F5F5F5",
        "color": "#525252",
        "borderRadius": "0.5rem"
      }
    },
    "input": {
      "background": "#FFFFFF",
      "border": "1px solid #D4D4D4",
      "borderRadius": "0.5rem",
      "focusBorderColor": "#7C3AED",
      "focusRing": "0 0 0 3px rgba(124, 58, 237, 0.1)",
      "fontSize": "0.875rem",
      "padding": "0.625rem 0.875rem"
    },
    "tag": {
      "background": "#F5F5F5",
      "color": "#525252",
      "activeBackground": "#f3f0ff",
      "activeColor": "#6D28D9",
      "borderRadius": "9999px",
      "fontSize": "0.75rem",
      "padding": "0.25rem 0.75rem"
    },
    "table": {
      "headerBackground": "#FAFAFA",
      "headerColor": "#737373",
      "headerFontSize": "0.75rem",
      "headerFontWeight": 600,
      "cellPadding": "1rem 1.5rem",
      "borderColor": "#F5F5F5",
      "hoverBackground": "#FAFAFA"
    },
    "statusBadge": {
      "borderRadius": "9999px",
      "fontSize": "0.75rem",
      "fontWeight": 600,
      "padding": "0.25rem 0.75rem"
    },
    "footer": {
      "background": "#FAFAFA",
      "borderTop": "1px solid #E5E5E5",
      "color": "#737373",
      "fontSize": "0.875rem",
      "paddingY": "2rem"
    }
  },
  "layout": {
    "grid": {
      "columns": {
        "cards": 3,
        "cardsMd": 2,
        "cardsSm": 1
      },
      "gap": "1.5rem"
    },
    "breakpoints": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px"
    }
  },
  "animations": {
    "transition": {
      "fast": "150ms ease",
      "normal": "200ms ease",
      "slow": "300ms ease"
    },
    "hover": {
      "scale": 1.02,
      "translateY": "-2px"
    }
  },
  "iconography": {
    "style": "SVG inline icons (no emojis)",
    "size": {
      "sm": "1rem",
      "md": "1.25rem",
      "lg": "1.5rem",
      "xl": "2rem"
    },
    "color": {
      "default": "#737373",
      "primary": "#7C3AED",
      "muted": "#A3A3A3"
    }
  }
}
